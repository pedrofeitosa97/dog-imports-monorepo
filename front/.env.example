# =============================================================================
# DOG IMPORTS — Frontend (React + Vite)
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
#
# Todas as variáveis DEVEM começar com VITE_ para serem expostas ao browser
# =============================================================================

# -----------------------------------------------------------------------------
# API
# URL base da API NestJS (sem barra no final)
# Desenvolvimento: http://localhost:8000/api
# Produção: URL do seu serviço no Railway
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# STRIPE — Pagamentos (chave pública, exposta ao browser)
# Stripe Dashboard → Developers → API Keys → Publishable key
# Use pk_test_ em desenvolvimento e pk_live_ em produção
# -----------------------------------------------------------------------------
VITE_STRIPE_PUBLIC_KEY=

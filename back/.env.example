# =============================================================================
# DOG IMPORTS — API (NestJS)
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
PORT=8000
NODE_ENV=development
# NODE_ENV=production  ← use em produção (Railway define automaticamente)

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO JWT
# Gere uma chave forte com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# OBRIGATÓRIO — o servidor recusa iniciar sem esta variável
# -----------------------------------------------------------------------------
JWT_SECRET=

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# Sem DATABASE_URL: usa SQLite local (arquivo dog_imports.db)
# Com DATABASE_URL: usa PostgreSQL (Railway, Supabase, Neon...)
# -----------------------------------------------------------------------------
DATABASE_URL=
# Exemplo Railway PostgreSQL:
# DATABASE_URL=postgresql://postgres:senha@host.railway.app:5432/railway

# -----------------------------------------------------------------------------
# CORS
# URL do frontend autorizado a acessar a API
# Sem valor: aceita qualquer origem (ok para desenvolvimento local)
# -----------------------------------------------------------------------------
FRONTEND_URL=
# Exemplo produção: https://dog-imports.vercel.app

# -----------------------------------------------------------------------------
# AWS S3 — Armazenamento de imagens
# Crie um bucket S3 e um usuário IAM com permissão PutObject/DeleteObject
# Sem essas variáveis, o upload de imagens fica indisponível
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# -----------------------------------------------------------------------------
# RESEND — E-mails transacionais
# Crie conta gratuita em https://resend.com → API Keys → Create API Key
# Sem esta variável, e-mails não são enviados (loja continua funcionando)
# Para testar sem domínio verificado: use o endpoint /admin/emails → Teste
# -----------------------------------------------------------------------------
RESEND_API_KEY=

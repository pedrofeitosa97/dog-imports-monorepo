# ── Servidor ──────────────────────────────────────────
PORT=8000

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_secreta_forte_64_chars

# ── Database ──────────────────────────────────────────
# Deixe vazio para usar SQLite local (desenvolvimento)
# Em produção (Railway), cole a URL do PostgreSQL aqui
DATABASE_URL=

# ── CORS ──────────────────────────────────────────────
# URL do frontend em produção (Vercel)
FRONTEND_URL=https://seu-projeto.vercel.app

# ── Cloudinary (uploads de imagens em produção) ───────
# Crie uma conta gratuita em https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
